# ─────────────────────────────────────────────────────────────────────────────
# MARKET DATA PROVIDERS  (server-side only; NEVER prefix with NEXT_PUBLIC_)
# Order of failover: Polygon  →  Finnhub  →  Alpha Vantage
# ─────────────────────────────────────────────────────────────────────────────
POLYGON_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Cache TTLs (seconds). When market is OPEN we use LIVE_TTL, else CLOSED_TTL.
PRICE_LIVE_TTL_SECONDS=15
PRICE_CLOSED_TTL_SECONDS=600

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: SUPABASE (used only if you wire cloud sync — see supabase/schema.sql)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: PUSH NOTIFICATIONS (Web Push VAPID keys)
# Generate with:  npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
